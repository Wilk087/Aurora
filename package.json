{
  "name": "aurora-player",
  "version": "2.7.0-dev",
  "private": true,
  "description": "A beautiful local music player for Linux and Windows",
  "author": {
    "name": "Wilk087",
    "email": "business@wilk087.dev"
  },
  "license": "GPL-3.0-or-later",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "dist": "npm run build && electron-builder --linux",
    "dist:pacman": "npm run build && electron-builder --linux pacman",
    "dist:appimage": "npm run build && electron-builder --linux AppImage",
    "dist:win": "npm run build && electron-builder --win",
    "dist:all": "npm run build && electron-builder --linux --win"
  },
  "build": {
    "appId": "com.wilk087.aurora-player",
    "productName": "Aurora Player",
    "artifactName": "aurora-player-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "icon.png"
      }
    ],
    "fileAssociations": [
      {
        "ext": ["mp3", "flac", "ogg", "opus", "wav", "m4a", "aac", "wma"],
        "name": "Audio File",
        "description": "Audio file",
        "mimeType": "audio/mpeg",
        "role": "Viewer"
      }
    ],
    "linux": {
      "target": [
        "pacman",
        "AppImage"
      ],
      "icon": "build/icons",
      "category": "Audio",
      "executableName": "aurora-player",
      "mimeTypes": [
        "audio/mpeg",
        "audio/flac",
        "audio/ogg",
        "audio/opus",
        "audio/wav",
        "audio/x-wav",
        "audio/mp4",
        "audio/aac",
        "audio/x-ms-wma"
      ],
      "desktop": {
        "Name": "Aurora Player",
        "Comment": "A beautiful local music player",
        "Categories": "Audio;Music;Player;AudioVideo;",
        "Keywords": "music;player;audio;",
        "StartupWMClass": "aurora-player",
        "MimeType": "audio/mpeg;audio/flac;audio/ogg;audio/opus;audio/wav;audio/x-wav;audio/mp4;audio/aac;audio/x-ms-wma;"
      }
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "aurora-player-${version}-windows-${arch}-setup.${ext}"
    },
    "portable": {
      "artifactName": "aurora-player-${version}-windows-${arch}-portable.${ext}"
    },
    "pacman": {
      "depends": [
        "gstreamer",
        "gst-plugins-base",
        "gst-plugins-good"
      ]
    }
  },
  "dependencies": {
    "@xhayper/discord-rpc": "^1.3.0",
    "bonjour-service": "^1.3.0",
    "bufferutil": "^4.1.0",
    "dbus-next": "^0.10.2",
    "express": "^5.2.1",
    "hls.js": "^1.6.15",
    "music-metadata": "^7.14.0",
    "pinia": "^2.3.0",
    "utf-8-validate": "^6.0.0",
    "vue": "^3.5.0",
    "vue-router": "^4.5.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-vue": "^5.2.0",
    "autoprefixer": "^10.4.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vue-tsc": "^2.0.0"
  }
}
